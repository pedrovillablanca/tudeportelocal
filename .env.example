# ===========================================
# TuDeporteLocal - Environment Variables
# ===========================================
# Copia este archivo a .env.local y completa los valores

# -------------------------------------------
# SUPABASE (Requerido)
# -------------------------------------------
# URL de tu proyecto Supabase
# Ejemplo: https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública de Supabase (safe para cliente)
# Encuentra esto en: Supabase > Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -------------------------------------------
# ADMIN (Requerido)
# -------------------------------------------
# Contraseña para acceder al panel de administración
# Usa una contraseña segura y larga
NEXT_PUBLIC_ADMIN_PASSWORD=

# -------------------------------------------
# SITIO (Opcional)
# -------------------------------------------
# URL del sitio (para sitemap y metadata)
# Por defecto usa https://tudeportelocal.cl si no está definido
# NEXT_PUBLIC_SITE_URL=https://tudeportelocal.cl

# -------------------------------------------
# NOTAS
# -------------------------------------------
# 1. Las variables con prefijo NEXT_PUBLIC_ son seguras para el navegador
# 2. NUNCA subas .env.local a Git (ya está ignorado en .gitignore)
# 3. En Vercel, configura estas variables en el dashboard de tu proyecto
# -------------------------------------------
